{
  "version": 2,
  "installCommand": "cd DuramatFront && npm ci",
  "buildCommand": "cd DuramatFront && npm run build",
  "outputDirectory": "DuramatFront/dist/DuramatFront",
  "rewrites": [
    {
      "source": "/ping",
      "destination": "/ping.html"
    },
    {
      "source": "/((?!ping|api|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}